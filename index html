<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>LIVEFY TV</title>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:linear-gradient(180deg,#020b1c,#03142d);
color:#fff;
overflow:hidden;
}

/* TOPBAR */

.topbar{
height:52px;
background:#ff005c;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 10px;
font-size:12px;
font-weight:bold;
overflow:hidden;
}

.notice{
background:#000;
padding:16px;
flex-shrink:0;
}

.notice-text{
white-space:nowrap;
overflow:hidden;
text-overflow:ellipsis;
padding:0 10px;
}

.clock{
background:#b30044;
padding:10px 14px;
border-radius:30px;
font-size:11px;
white-space:nowrap;
}

/* PLAYER */

.player-wrapper{
position:relative;
width:100%;
padding:12px;
}

.live-btn{
position:absolute;
top:24px;
left:50%;
transform:translateX(-50%);
background:#ff005c;
padding:12px 28px;
border-radius:40px;
font-size:20px;
font-weight:bold;
z-index:999;
box-shadow:0 0 20px #ff005c;
}

.player{
width:100%;
height:260px;
background:#000;
border-radius:18px;
overflow:hidden;
box-shadow:0 0 25px rgba(255,0,92,0.2);
}

video{
width:100%;
height:100%;
object-fit:cover;
background:#000;
}

/* CONTENT */

.content{
height:calc(100vh - 390px);
overflow-y:auto;
padding:15px;
padding-bottom:120px;
}

/* TITLE */

.section-title{
font-size:14px;
letter-spacing:6px;
margin-bottom:18px;
color:#9ba8c7;
}

/* SEARCH */

.search{
width:100%;
padding:18px;
background:linear-gradient(90deg,#08152d,#0a1f3d);
border:none;
border-radius:18px;
color:#fff;
font-size:18px;
margin-bottom:22px;
outline:none;
}

/* GRID */

.grid{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:12px;
}

/* CARD */

.card{
background:linear-gradient(180deg,#071427,#081a34);
border-radius:18px;
padding:14px 8px;
text-align:center;
border:1px solid rgba(255,255,255,0.05);
transition:0.3s;
min-height:150px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
cursor:pointer;
}

.card:hover{
transform:translateY(-4px);
box-shadow:0 0 20px rgba(255,0,92,0.25);
}

.card img{
width:78px;
height:50px;
object-fit:contain;
margin-bottom:14px;
border-radius:10px;
}

.card h3{
font-size:14px;
font-weight:500;
line-height:20px;
}

/* NAV */

.nav{
position:fixed;
bottom:0;
left:0;
width:100%;
height:85px;
background:#04122a;
display:flex;
justify-content:space-around;
align-items:center;
border-top:1px solid rgba(255,255,255,0.08);
}

.nav-item{
text-align:center;
font-size:15px;
color:#8ea2c8;
}

.active{
color:#ff005c;
}

/* SCROLL */

::-webkit-scrollbar{
width:5px;
}

::-webkit-scrollbar-thumb{
background:#ff005c;
border-radius:20px;
}

/* MOBILE */

@media(max-width:768px){

.grid{
grid-template-columns:repeat(2,1fr);
}

.player{
height:220px;
}

.card{
min-height:170px;
}

.card img{
width:85px;
height:60px;
}

.live-btn{
font-size:18px;
padding:10px 24px;
}

}

</style>

</head>

<body>

<!-- TOPBAR -->

<div class="topbar">

<div class="notice">
NOTICE
</div>

<div class="notice-text">
সব চ্যানেল লোড হতে ১০-১৫ সেকেন্ড সময় লাগতে পারে
</div>

<div class="clock" id="clock">
Loading...
</div>

</div>

<!-- PLAYER -->

<div class="player-wrapper">

<div class="live-btn">
⚪ LIVE TV
</div>

<div class="player">

<video
id="video"
controls
autoplay
playsinline
preload="none">
</video>

</div>

</div>

<!-- CONTENT -->

<div class="content">

<div class="section-title">
PREMIUM TV CHANNELS
</div>

<input
type="text"
class="search"
id="search"
placeholder="🔍 Search channels...">

<div class="grid"
id="channels">
</div>

</div>

<!-- NAV -->

<div class="nav">

<div class="nav-item active">
🏠<br>HOME
</div>

<div class="nav-item">
📺<br>LIVE TV
</div>

</div>

<script>

/* CLOCK */

function updateClock(){

const now = new Date();

const bd = now.toLocaleString(
'en-GB',
{
timeZone:'Asia/Dhaka',
weekday:'short',
day:'2-digit',
month:'short',
year:'numeric',
hour:'2-digit',
minute:'2-digit',
second:'2-digit'
});

document.getElementById(
'clock'
).innerHTML = bd;
}

setInterval(updateClock,1000);

updateClock();

/* LOAD CHANNELS */

fetch('channels.json')

.then(res => res.json())

.then(data => {

window.allChannels = data.channels;

loadChannels(data.channels);

})

.catch(err=>{

document.getElementById('channels')
.innerHTML =
'<h2 style="padding:20px">channels.json not found</h2>';

});

/* SHOW CHANNELS */

function loadChannels(channels){

let html = '';

channels.forEach(ch => {

html += `

<div class="card"
onclick="playChannel('${ch.url}')">

<img
loading="lazy"
src="${ch.logo || 'https://cdn-icons-png.flaticon.com/512/810/810228.png'}"
onerror="this.src='https://cdn-icons-png.flaticon.com/512/810/810228.png'">

<h3>${ch.name}</h3>

</div>

`;

});

document.getElementById(
'channels'
).innerHTML = html;
}

/* PLAYER */

function playChannel(url){

const video =
document.getElementById('video');

if(Hls.isSupported()){

if(window.hls){
window.hls.destroy();
}

const hls = new Hls({
enableWorker:true,
lowLatencyMode:true
});

window.hls = hls;

hls.loadSource(url);

hls.attachMedia(video);

hls.on(
Hls.Events.MANIFEST_PARSED,
function(){

video.play();

});

hls.on(Hls.Events.ERROR,
function(){

console.log("Stream Error");

});

}else{

video.src = url;

video.play();
}
}

/* SEARCH */

document
.getElementById('search')

.addEventListener('keyup',

function(){

const value =
this.value.toLowerCase();

const filtered =
window.allChannels.filter(ch=>

ch.name.toLowerCase()
.includes(value)

);

loadChannels(filtered);

});

</script>

</body>
</html>
