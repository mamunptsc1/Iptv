<!DOCTYPE html>
<html lang="bn">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>LIVE TV</title>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
margin:0;
padding:0;
font-family:Arial,sans-serif;
background:
radial-gradient(circle at top left,#153cff55,transparent 25%),
radial-gradient(circle at top right,#ff006655,transparent 25%),
linear-gradient(180deg,#020617,#07152e,#081f45);
background-attachment:fixed;
color:#fff;
overflow:hidden;
}

/* TOPBAR */

.topbar{
height:60px;
background:rgba(255,255,255,0.06);
backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);
display:flex;
align-items:center;
justify-content:space-between;
padding:0 12px;
border-bottom:1px solid rgba(255,255,255,0.08);
box-shadow:0 8px 30px rgba(0,0,0,0.25);
}

.notice{
background:#000;
  display:flex;
align-items:center;
justify-content:center;
padding:18px;
font-size:14px;
font-weight:bold;
border-radius:14px;
}

.notice-text{
flex:1;
overflow:hidden;
white-space:nowrap;
margin:0 6px;
font-size:11px;
}

.notice-text span{
display:inline-block;
padding-left:100%;
animation:marquee 14s linear infinite;
}

@keyframes marquee{
0%{
transform:translateX(0);
}
100%{
transform:translateX(-100%);
}
}

.clock{
background:
linear-gradient(90deg,#ff0066,#ff0055);
padding:12px 18px;
border-radius:30px;
font-size:12px;
font-weight:bold;
box-shadow:
0 0 20px rgba(255,0,102,0.45);
}

/* PLAYER */

.player-wrapper{
padding:14px;
}

.player{
height:250px;
border-radius:30px;
overflow:hidden;
position:relative;

background:
rgba(255,255,255,0.08);

backdrop-filter:blur(24px);
-webkit-backdrop-filter:blur(24px);

border:
1px solid rgba(255,255,255,0.08);

box-shadow:
0 0 40px rgba(0,140,255,0.18);
}

.player::before{
content:'';
position:absolute;
inset:0;
background:
linear-gradient(
180deg,
transparent,
rgba(255,255,255,0.04)
);
pointer-events:none;
z-index:2;
}

video{
width:100%;
height:100%;
object-fit:contain;
background:#000;
}
video:fullscreen{
object-fit:contain;
background:#000;
}

video:-webkit-full-screen{
object-fit:contain;
background:#000;
}
/* CONTENT */

.content{
height:calc(100vh - 360px);
overflow-y:auto;
padding:16px;
padding-bottom:90px;
overflow-x:hidden;
}

/* TITLE */

.section-title{
font-size:16px;
letter-spacing:8px;
margin-bottom:22px;
color:#d6ddff;
font-weight:300;
}

/* CATEGORY */

.category-bar{
display:flex;
gap:12px;
margin-bottom:22px;
overflow-x:auto;
}

.category-btn{
background:
rgba(255,255,255,0.08);

backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);

padding:12px 20px;

border-radius:15px;

font-size:14px;

font-weight:600;

border:
1px solid rgba(255,255,255,0.08);

transition:0.35s;

cursor:pointer;

color:#fff;

box-shadow:
0 4px 20px rgba(0,0,0,0.18);
}

.category-btn.active{
background:
linear-gradient(90deg,#ff0066,#ff0055);

box-shadow:
0 0 25px rgba(255,0,120,0.45);
}

/* SEARCH */

.search{
width:100%;
padding:14px;
border:none;
outline:none;

border-radius:18px;

background:
rgba(255,255,255,0.06);

backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);

color:#fff;

font-size:15px;

margin-bottom:18px;

border:
1px solid rgba(255,255,255,0.08);
}

/* GRID */

.grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:14px;
}

/* CARD */

.card{

background:
linear-gradient(
180deg,
rgba(255,255,255,0.10),
rgba(255,255,255,0.03)
);

backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);

border-radius:28px;

padding:18px 10px;

text-align:center;

border:
1px solid rgba(255,255,255,0.08);

transition:0.35s;

min-height:170px;

display:flex;
flex-direction:column;
justify-content:center;
align-items:center;

overflow:hidden;

position:relative;

box-shadow:
0 8px 30px rgba(0,0,0,0.22);

cursor:pointer;
}

.card::before{
content:'';
position:absolute;
top:-40%;
left:-40%;
width:180%;
height:180%;

background:
linear-gradient(
45deg,
transparent,
rgba(255,255,255,0.05),
transparent
);

transform:rotate(25deg);
}

.card:hover{

transform:
translateY(-8px)
scale(1.03);

box-shadow:
0 0 35px rgba(255,0,120,0.45);

border:
1px solid rgba(255,255,255,0.16);
}

.card.active{
border:
2px solid #ff0066;

box-shadow:
0 0 35px rgba(255,0,120,0.55);
}

.card img{
width:60px;
height:45px;
object-fit:contain;
background:#fff;
padding:6px;
border-radius:16px;
margin-bottom:14px;
z-index:2;
}

.card h3{
font-size:15px;
font-weight:500;
line-height:22px;
z-index:2;
}

/* FOOTER */

.footer{
position:fixed;
bottom:0;
left:0;
width:100%;
height:52px;

background:#04122a;

display:flex;
align-items:center;
justify-content:center;
padding-bottom:0;
  
font-size:13px;
font-weight:bold;

color:#ff0066;

border-top:
1px solid rgba(255,255,255,0.08);

z-index:999;
}

/* LOADER */

#loader{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
background:rgba(0,0,0,0.75);
padding:14px 24px;
border-radius:16px;
display:none;
z-index:999;
font-size:15px;
color:#fff;
backdrop-filter:blur(12px);
}

/* SCROLL */

::-webkit-scrollbar{
width:4px;
}

::-webkit-scrollbar-thumb{
background:#ff0066;
border-radius:20px;
}

/* MOBILE */

@media(max-width:768px){

.topbar{
height:55px;
padding:0 8px;
}

.notice{
padding:14px;
font-size:12px;
border-radius:10px;
}

.clock{
padding:10px 14px;
font-size:10px;
}

.player{
height:210px;
border-radius:24px;
}

.section-title{
font-size:14px;
letter-spacing:5px;
}

.category-btn{
padding:12px 18px;
font-size:14px;
border-radius:14px;
}

.search{
padding:15px;
font-size:15px;
}

.grid{
gap:12px;
}

.card{
min-height:150px;
border-radius:22px;
padding:14px 8px;
}

.card img{
width:60px;
height:45px;
}

.card h3{
font-size:13px;
line-height:18px;
}

.footer{
height:60px;
font-size:14px;
display:flex;
align-items:center;
justify-content:center;
padding-bottom:0;
  }

}
/* PC + ANDROID TV */

@media(min-width:1024px){

.player-wrapper{
width:72%;
float:left;
padding:20px;
}

.content{
width:28%;
float:right;
height:100vh;
padding-top:20px;
overflow-y:auto;
}

.player{
height:420px;
}

.grid{
grid-template-columns:repeat(2,1fr);
gap:18px;
}

.card{
min-height:180px;
}

.section-title{
font-size:18px;
}

.search{
font-size:18px;
}

.category-btn{
font-size:16px;
padding:14px 24px;
}

.footer{
font-size:18px;
}

}

</style>

</head>

<body>

<!-- TOPBAR -->

<div class="topbar">

<div class="notice">
NOTICE
</div>

<div class="notice-text">
<span>
সব চ্যানেল লোড হতে ১০-১৫ সেকেন্ড সময় লাগতে পারে
</span>
</div>

<div class="clock" id="clock">
Loading...
</div>

</div>

<!-- PLAYER -->

<div class="player-wrapper">

<div class="player">
<div id="loader">
Loading Channel...
</div>
  
<video
id="video"
controls
autoplay
playsinline>
</video>

</div>

</div>

<!-- CONTENT -->

<div class="content">

<div class="section-title">
PREMIUM TV CHANNELS
</div>
<div class="category-bar">

<div class="category-btn active"
onclick="filterCategory('all',this)">
ALL (<span id="allCount">0</span>)
</div>

<div class="category-btn"
onclick="filterCategory('bangla',this)">
BANGLA
</div>

<div class="category-btn"
onclick="filterCategory('sport',this)">
SPORT
</div>

</div>
  
<input
type="text"
class="search"
id="search"
placeholder="Search channels...">

<div class="grid"
id="channels">
</div>

</div>

<!-- FOOTER -->

<div class="footer">
MADE BY MD MAMUNUR RASHID
</div>

<script>

/* CLOCK */

function updateClock(){

const now = new Date();

const days = [
'রবিবার',
'সোমবার',
'মঙ্গলবার',
'বুধবার',
'বৃহস্পতিবার',
'শুক্রবার',
'শনিবার'
];

const months = [
'জানুয়ারি',
'ফেব্রুয়ারি',
'মার্চ',
'এপ্রিল',
'মে',
'জুন',
'জুলাই',
'আগস্ট',
'সেপ্টেম্বর',
'অক্টোবর',
'নভেম্বর',
'ডিসেম্বর'
];

const bdTime =
new Date(
now.toLocaleString(
'en-US',
{
timeZone:'Asia/Dhaka'
}
)
);

let hour =
bdTime.getHours();

const minute =
String(
bdTime.getMinutes()
).padStart(2,'0');

const second =
String(
bdTime.getSeconds()
).padStart(2,'0');

const ampm =
hour >= 12 ? 'PM' : 'AM';

hour = hour % 12;

hour = hour ? hour : 12;

const day =
days[bdTime.getDay()];

const date =
bdTime.getDate();

const month =
months[bdTime.getMonth()];

const year =
bdTime.getFullYear();

document.getElementById(
'clock'
).innerHTML =
`${day}, ${date} ${month} ${year} | ${hour}:${minute}:${second} ${ampm}`;

}
setInterval(updateClock,1000);

updateClock();
  
/* LOAD CHANNELS */

fetch('channels.json')

.then(res => res.json())

.then(data => {

window.allChannels = data.channels;
  document.getElementById(
'allCount'
).innerText =
data.channels.length;

loadChannels(data.channels);
  const saved =
localStorage.getItem('lastChannel');

if(saved){

setTimeout(()=>{

playChannel(
saved,
document.querySelector('.card')
);

},1500);

}
setTimeout(()=>{

const first =
window.allChannels[0];

playChannel(
first.url,
document.querySelectorAll('.card')[0]
);

},1000);
});

/* SHOW CHANNELS */

function loadChannels(channels){

let html = '';

channels.forEach(ch => {

html += `

<div class="card"
onclick="playChannel('${ch.url}', this)">

<img
src="${ch.logo || 'https://cdn-icons-png.flaticon.com/512/810/810228.png'}"
onerror="this.src='https://cdn-icons-png.flaticon.com/512/810/810228.png'">

<h3>${ch.name}</h3>

</div>

`;

});

document.getElementById(
'channels'
).innerHTML = html;
}

/* PLAYER */
function playChannel(url,card){

localStorage.setItem(
'lastChannel',
url
);

const video =
document.getElementById('video');

document.getElementById('loader')
.style.display='block';

if(Hls.isSupported()){

if(window.hls){
window.hls.destroy();
}

const hls = new Hls({

enableWorker:true,
lowLatencyMode:true

});

window.hls = hls;

hls.loadSource(url);

hls.attachMedia(video);

hls.on(
Hls.Events.MANIFEST_PARSED,
function(){

video.play();

document.getElementById('loader')
.style.display='none';

});

hls.on(
Hls.Events.ERROR,
function(){

document.getElementById('loader')
.style.display='none';

});

}else{

video.src = url;

video.onloadedmetadata = function(){

video.play();

document.getElementById('loader')
.style.display='none';

};

}

}
/* SEARCH */

document
.getElementById('search')

.addEventListener(
'keyup',

function(){

const value =
this.value.toLowerCase();

const filtered =
window.allChannels.filter(ch=>

ch.name
.toLowerCase()
.includes(value)

);

loadChannels(filtered);

});

/* REMOTE VOLUME */

document.addEventListener(
'keydown',
function(e){

const video =
document.getElementById('video');

if(e.key === 'ArrowRight'){

if(video.volume < 1){
video.volume += 0.1;
}

}

if(e.key === 'ArrowLeft'){

if(video.volume > 0){
video.volume -= 0.1;
}

}

});
function filterCategory(type,el){

document
.querySelectorAll('.category-btn')
.forEach(btn=>{
btn.classList.remove('active');
});

el.classList.add('active');

let filtered = [];

if(type === 'all'){

filtered = window.allChannels;

}

else if(type === 'bangla'){

filtered =
window.allChannels.filter(ch=>

ch.category &&
ch.category.toLowerCase() === 'bangla'

);

}

else if(type === 'sport'){

filtered =
window.allChannels.filter(ch=>

ch.category &&
ch.category.toLowerCase() === 'sport'

);

}

loadChannels(filtered);

}
  let currentIndex = 0;

/* REMOTE CONTROL */

document.addEventListener(
'keydown',
function(e){

const video =
document.getElementById('video');

/* CHANNEL DOWN */

if(e.key === 'ArrowDown'){

e.preventDefault();

if(currentIndex <
window.allChannels.length - 1){

currentIndex++;

const ch =
window.allChannels[currentIndex];

playChannel(
ch.url,
document.querySelectorAll('.card')[currentIndex]
);

}

}

/* CHANNEL UP */

if(e.key === 'ArrowUp'){

e.preventDefault();

if(currentIndex > 0){

currentIndex--;

const ch =
window.allChannels[currentIndex];

playChannel(
ch.url,
document.querySelectorAll('.card')[currentIndex]
);

}

}

/* VOLUME UP */

if(e.key === 'ArrowRight'){

e.preventDefault();

if(video.volume < 1){

video.volume =
Math.min(
1,
video.volume + 0.1
);

}

}

/* VOLUME DOWN */

if(e.key === 'ArrowLeft'){

e.preventDefault();

if(video.volume > 0){

video.volume =
Math.max(
0,
video.volume - 0.1
);

}

}

/* MUTE */

if(e.key === 'm'){

video.muted =
!video.muted;

}

});
</script>

</body>

</html>
